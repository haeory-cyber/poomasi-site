# seed-server (및 품앗이 봇 공통) 환경변수 — 키 이름만, 값은 절대 git에 X
#
# 실제 사용:
#   1. 이 파일을 /home/haeory/poomasi/.env 로 복사 (cp infra/.env.example /home/haeory/poomasi/.env)
#   2. 권한 600 적용 (chmod 600 /home/haeory/poomasi/.env)
#   3. 각 키에 실제 값 채워넣기
#   4. systemctl restart seed-server 로 반영
#
# 이 21개 키는 seed-server.service의 EnvironmentFile=/home/haeory/poomasi/.env 에서 읽힘.
# seed_server.py 자체가 모두 사용하는 건 아니며, 같은 .env를 attendance_bot, barcode_bot,
# coop_bot 등 품앗이 봇 전체가 공유함.
#
# ── seed_server.py가 직접 사용하는 키 ──
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_JWT_SECRET=

# ── 타 봇이 사용하는 공유 키 (참고) ──
TELEGRAM_BOT_TOKEN=
JIMMY_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SUPABASE_SECRET_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_URL=
SUPABASE_PUBLISHABLE_KEY=
GEMINI_API_KEY=
GITHUB_TOKEN=
ECOUNT_API_KEY=
KAKAO_API_KEY=
BIZINFO_API_KEY=
ANTHROPIC_API_KEY=
TELEGRAM_ORDER_BOT_TOKEN=
CLOUDFLARE_API_TOKEN=
MCP_API_KEY=
POOMASI_AI_TEAM_CHAT_ID=
PAMI_BOT_TOKEN=
COOP_BOT_TOKEN=
